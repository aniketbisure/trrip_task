# GEMINI_API_KEY: Required for Gemini API itinerary generation (gemini-3.5-flash)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted or run locally.
APP_URL="http://localhost:3000"

# VITE_API_PROXY_TARGET: Backend URL used by the Vite dev server for /api requests.
VITE_API_PROXY_TARGET="https://trrip-task-1.onrender.com"

# PORT: Render injects this automatically in production.
PORT="3000"

# FRONTEND_URL: Comma-separated allowed browser origins if the API is called from another domain.
# Leave empty for same-origin deployments.
FRONTEND_URL=""

# MONGODB_URI: MongoDB connection connection string.
# Required in production. Development falls back to local filesystem storage if not provided.
MONGODB_URI="mongodb://localhost:27017/your-database-name"

# JWT_SECRET: Secret key for signing authentication JSON Web Tokens.
JWT_SECRET="Enter your key here"
