# GEMINI_API_KEY: Required for Gemini API itinerary generation (gemini-3.5-flash)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted or run locally.
APP_URL="http://localhost:3000"

# MONGODB_URI: MongoDB connection connection string.
# Falls back to local filesystem storage (data/ folder) if not provided.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/trrip"

# JWT_SECRET: Secret key for signing authentication JSON Web Tokens.
JWT_SECRET="5f24ec8139ec01069bd2b5d1467bfe9a00e12d37ad49227c40c519a38f045885"

